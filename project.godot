; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="monster-lab"
run/main_scene="uid://dvfumklriwrf3"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

DataManager="*res://scripts/global/data_manager.gd"
SignalManager="*res://scripts/global/signal_manager.gd"
SoundManager="*res://scripts/global/sound_manager.gd"
PlayerManager="*res://scripts/global/player_manager.gd"
GameManager="*res://scripts/global/game_manager.gd"
EntityManager="*res://scripts/global/entity_manager.gd"
MonsterManager="*res://scripts/global/monster_manager.gd"
LocationManager="*res://scripts/global/location_manager.gd"
ProductionManager="*res://scripts/global/production_manager.gd"
NpcManager="*res://scripts/global/NPC_manager.gd"
OrderManager="*uid://d1vi2lq44rplc"
QuestManager="*uid://w5jo6j331813"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/vsync/vsync_mode=0

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

